# Copy this file to .env.local and fill in your values

# Supabase (from your Supabase project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Panel Password (choose any password you want)
ADMIN_PASSWORD=your-secret-password-here

# Optional: OpenAI API key for announcement auto-fill (Admin → paste text → Auto-fill title & details)
# Get one at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
